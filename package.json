{
  "name": "employee-onboarding-platform",
  "version": "1.0.0",
  "description": "Enterprise employee onboarding platform built with SAP CAP and Fiori Elements",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build",
    "clean": "rm -rf gen mta_archives resources app/*/dist app/*/archive && npm cache clean --force",
    "test": "cds compile db srv --to csn",
    "watch-employees": "cds watch --open employees/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-departments": "cds watch --open departments/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-onboarding-tasks": "cds watch --open onboardingtasks/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-documents": "cds watch --open documents/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-assets": "cds watch --open assets/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-trainings": "cds watch --open trainings/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-dashboard": "cds watch --open dashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-reports": "cds watch --open reports/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.8.0",
    "express": "^5"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.9.2",
    "cds-plugin-ui5": "^0.14"
  },
  "engines": {
    "node": ">=22"
  },
  "cds": {
    "features": {
      "fiori_preview": true
    },
    "fiori": {
      "draft_deletion_timeout": "14d"
    },
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db/onboarding.db"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "john.smith@company.com": {
              "roles": [
                "HRAdmin"
              ]
            },
            "priya.sharma@company.com": {
              "roles": [
                "HRManager"
              ]
            },
            "sarah.connor@company.com": {
              "roles": [
                "ITAdmin"
              ]
            },
            "emily.chen@company.com": {
              "roles": [
                "Employee"
              ]
            }
          }
        },
        "[production]": {
          "kind": "xsuaa"
        }
      }
    }
  },
  "workspaces": [
    "app/assets",
    "app/dashboard",
    "app/departments",
    "app/documents",
    "app/employees",
    "app/onboarding-tasks",
    "app/reports",
    "app/trainings"
  ],
  "sapux": [
    "app/employees",
    "app/departments",
    "app/onboarding-tasks",
    "app/documents",
    "app/assets",
    "app/trainings",
    "app/dashboard",
    "app/reports"
  ],
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashadmuneer/cds-hrms.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ashadmuneer/cds-hrms/issues"
  },
  "homepage": "https://github.com/ashadmuneer/cds-hrms#readme"
}
