{
  "xsappname": "employee-onboarding-platform",
  "tenant-mode": "dedicated",
  "scopes": [
    { "name": "$XSAPPNAME.HRAdmin", "description": "HR Administrator" },
    { "name": "$XSAPPNAME.HRManager", "description": "HR Manager" },
    { "name": "$XSAPPNAME.ITAdmin", "description": "IT Administrator" },
    { "name": "$XSAPPNAME.Employee", "description": "Employee" }
  ],
  "role-templates": [
    {
      "name": "HRAdmin",
      "description": "HR Administrator Role",
      "scope-references": ["$XSAPPNAME.HRAdmin"]
    },
    {
      "name": "Employee",
      "description": "Standard Employee Role",
      "scope-references": ["$XSAPPNAME.Employee"]
    }
  ]
}