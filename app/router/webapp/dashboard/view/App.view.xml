<mvc:View
    controllerName="dashboard.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <App>
        <Page
            title="Onboarding Dashboard"
            showNavButton="false"
            class="dashboardPage">
            <customHeader>
                <OverflowToolbar class="dashboardHeader">
                    <Title text="Onboarding Dashboard" level="H1"/>
                    <ToolbarSpacer/>
                    <ObjectStatus
                        text="{dashboard>/lastUpdatedText}"
                        icon="sap-icon://synchronize"
                        state="Information"/>
                    <ObjectStatus
                        text="{dashboard>/session/userText}"
                        icon="sap-icon://person-placeholder"
                        state="None"/>
                    <ObjectStatus
                        text="{dashboard>/session/roleText}"
                        icon="sap-icon://key-user-settings"
                        state="Information"/>
                    <Button
                        text="Employees"
                        icon="sap-icon://employee"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/employees}">
                        <customData>
                            <core:CustomData key="target" value="employees"/>
                        </customData>
                    </Button>
                    <Button
                        text="Departments"
                        icon="sap-icon://org-chart"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/departments}">
                        <customData>
                            <core:CustomData key="target" value="departments"/>
                        </customData>
                    </Button>
                    <Button
                        text="Tasks"
                        icon="sap-icon://task"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/tasks}">
                        <customData>
                            <core:CustomData key="target" value="tasks"/>
                        </customData>
                    </Button>
                    <Button
                        text="Documents"
                        icon="sap-icon://documents"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/documents}">
                        <customData>
                            <core:CustomData key="target" value="documents"/>
                        </customData>
                    </Button>
                    <Button
                        text="Assets"
                        icon="sap-icon://laptop"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/assets}">
                        <customData>
                            <core:CustomData key="target" value="assets"/>
                        </customData>
                    </Button>
                    <Button
                        text="Training"
                        icon="sap-icon://learning-assistant"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/trainings}">
                        <customData>
                            <core:CustomData key="target" value="trainings"/>
                        </customData>
                    </Button>
                    <Button
                        text="Reports"
                        icon="sap-icon://business-objects-experience"
                        type="Transparent"
                        press=".onNavigate"
                        visible="{dashboard>/session/access/reports}">
                        <customData>
                            <core:CustomData key="target" value="reports"/>
                        </customData>
                    </Button>
                    <Button
                        icon="sap-icon://refresh"
                        type="Transparent"
                        tooltip="Refresh"
                        press=".onRefresh"/>
                    <ToolbarSeparator/>
                    <Button
                        icon="sap-icon://home"
                        text="Home"
                        type="Transparent"
                        tooltip="Back to Launchpad"
                        press=".onHome"/>
                    <Button
                        icon="sap-icon://log"
                        text="Sign Out"
                        type="Transparent"
                        tooltip="Sign Out"
                        press=".onLogout"/>
                </OverflowToolbar>
            </customHeader>
            <content>
                <ScrollContainer height="100%" vertical="true" horizontal="false">
                    <VBox class="dashboardShell" busy="{dashboard>/busy}">
                        <HBox class="dashboardHero" renderType="Bare" wrap="Wrap" alignItems="Center">
                            <VBox class="dashboardHeroText">
                                <Title text="Employee Onboarding Command Center" level="H2"/>
                                <Text text="Operational view across people, tasks, documents, assets, and training readiness." class="dashboardSubtleText"/>
                            </VBox>
                            <ToolbarSpacer/>
                            <HBox class="dashboardHeroMetrics" renderType="Bare" wrap="Wrap">
                                <ObjectNumber
                                    number="{dashboard>/kpis/avgProgress/value}"
                                    unit="%"
                                    emphasized="true"
                                    state="{dashboard>/kpis/avgProgress/state}"/>
                                <ObjectNumber
                                    number="{dashboard>/kpis/pendingTasks/value}"
                                    unit="Tasks"
                                    emphasized="true"
                                    state="{dashboard>/kpis/pendingTasks/state}"/>
                                <ObjectNumber
                                    number="{dashboard>/kpis/overdueTasks/value}"
                                    unit="Overdue"
                                    emphasized="true"
                                    state="{dashboard>/kpis/overdueTasks/state}"/>
                            </HBox>
                        </HBox>

                        <IconTabBar
                            expandable="false"
                            class="dashboardTabs"
                            selectedKey="overview">
                            <items>
                                <IconTabFilter key="overview" text="Overview" icon="sap-icon://business-objects-experience">
                                    <VBox class="dashboardTabContent">
                                        <FlexBox
                                            class="kpiGrid"
                                            renderType="Bare"
                                            wrap="Wrap"
                                            alignItems="Stretch">
                                            <GenericTile header="Employees" subheader="Total onboarded profiles" class="kpiTile navTile" press=".onNavigate">
                                                <customData>
                                                    <core:CustomData key="target" value="employees"/>
                                                </customData>
                                                <tileContent>
                                                    <TileContent unit="People">
                                                        <NumericContent
                                                            icon="sap-icon://employee"
                                                            value="{dashboard>/kpis/totalEmployees/value}"
                                                            valueColor="Neutral"/>
                                                    </TileContent>
                                                </tileContent>
                                            </GenericTile>
                                            <GenericTile header="Average Progress" subheader="Across active onboarding" class="kpiTile">
                                                <tileContent>
                                                    <TileContent unit="%">
                                                        <NumericContent
                                                            icon="sap-icon://process"
                                                            value="{dashboard>/kpis/avgProgress/value}"
                                                            valueColor="{dashboard>/kpis/avgProgress/color}"/>
                                                    </TileContent>
                                                </tileContent>
                                            </GenericTile>
                                            <GenericTile header="Pending Tasks" subheader="Open operational actions" class="kpiTile navTile" press=".onNavigate">
                                                <customData>
                                                    <core:CustomData key="target" value="tasks"/>
                                                </customData>
                                                <tileContent>
                                                    <TileContent unit="Open">
                                                        <NumericContent
                                                            icon="sap-icon://task"
                                                            value="{dashboard>/kpis/pendingTasks/value}"
                                                            valueColor="{dashboard>/kpis/pendingTasks/color}"/>
                                                    </TileContent>
                                                </tileContent>
                                            </GenericTile>
                                            <GenericTile header="Documents" subheader="Awaiting verification" class="kpiTile navTile" press=".onNavigate">
                                                <customData>
                                                    <core:CustomData key="target" value="documents"/>
                                                </customData>
                                                <tileContent>
                                                    <TileContent unit="Open">
                                                        <NumericContent
                                                            icon="sap-icon://documents"
                                                            value="{dashboard>/kpis/openDocuments/value}"
                                                            valueColor="{dashboard>/kpis/openDocuments/color}"/>
                                                    </TileContent>
                                                </tileContent>
                                            </GenericTile>
                                            <GenericTile header="Assets" subheader="Available for allocation" class="kpiTile navTile" press=".onNavigate">
                                                <customData>
                                                    <core:CustomData key="target" value="assets"/>
                                                </customData>
                                                <tileContent>
                                                    <TileContent unit="Available">
                                                        <NumericContent
                                                            icon="sap-icon://laptop"
                                                            value="{dashboard>/kpis/availableAssets/value}"
                                                            valueColor="Good"/>
                                                    </TileContent>
                                                </tileContent>
                                            </GenericTile>
                                            <GenericTile header="Training" subheader="Completion coverage" class="kpiTile navTile" press=".onNavigate">
                                                <customData>
                                                    <core:CustomData key="target" value="trainings"/>
                                                </customData>
                                                <tileContent>
                                                    <TileContent unit="%">
                                                        <NumericContent
                                                            icon="sap-icon://learning-assistant"
                                                            value="{dashboard>/kpis/trainingCompletion/value}"
                                                            valueColor="{dashboard>/kpis/trainingCompletion/color}"/>
                                                    </TileContent>
                                                </tileContent>
                                            </GenericTile>
                                        </FlexBox>

                                        <HBox class="dashboardColumns" renderType="Bare" wrap="Wrap" alignItems="Stretch">
                                            <Panel headerText="Department Progress" class="dashboardPanel">
                                                <List items="{dashboard>/departmentProgress}" showSeparators="Inner">
                                                    <CustomListItem>
                                                        <VBox class="chartRow">
                                                            <HBox justifyContent="SpaceBetween" alignItems="Center">
                                                                <ObjectIdentifier title="{dashboard>name}" text="{dashboard>countText}"/>
                                                                <ObjectNumber number="{dashboard>avgProgress}" unit="%" state="{dashboard>state}"/>
                                                            </HBox>
                                                            <ProgressIndicator
                                                                percentValue="{dashboard>avgProgress}"
                                                                displayValue="{dashboard>avgProgressText}"
                                                                state="{dashboard>state}"/>
                                                        </VBox>
                                                    </CustomListItem>
                                                </List>
                                            </Panel>

                                            <Panel headerText="Attention Required" class="dashboardPanel">
                                                <List items="{dashboard>/peopleAtRisk}" noDataText="No employee onboarding risks" showSeparators="Inner">
                                                    <ObjectListItem
                                                        title="{dashboard>name}"
                                                        number="{dashboard>progress}"
                                                        numberUnit="%"
                                                        numberState="{dashboard>state}"
                                                        intro="{dashboard>employeeNumber}">
                                                        <attributes>
                                                            <ObjectAttribute text="{dashboard>departmentName}"/>
                                                            <ObjectAttribute text="{dashboard>statusText}"/>
                                                        </attributes>
                                                    </ObjectListItem>
                                                </List>
                                            </Panel>
                                        </HBox>
                                    </VBox>
                                </IconTabFilter>

                                <IconTabFilter key="kpis" text="KPIs" icon="sap-icon://performance">
                                    <VBox class="dashboardTabContent">
                                        <HBox class="dashboardColumns" renderType="Bare" wrap="Wrap" alignItems="Stretch">
                                            <Panel headerText="Executive Scorecard" class="dashboardPanel widePanel">
                                                <VBox class="scorecard">
                                                    <HBox class="scorecardRow" justifyContent="SpaceBetween" alignItems="Center">
                                                        <Text text="Average Progress"/>
                                                        <ProgressIndicator
                                                            width="55%"
                                                            percentValue="{dashboard>/kpis/avgProgress/value}"
                                                            displayValue="{dashboard>/kpis/avgProgress/display}"
                                                            state="{dashboard>/kpis/avgProgress/state}"/>
                                                    </HBox>
                                                    <HBox class="scorecardRow" justifyContent="SpaceBetween" alignItems="Center">
                                                        <Text text="Training Completion"/>
                                                        <ProgressIndicator
                                                            width="55%"
                                                            percentValue="{dashboard>/kpis/trainingCompletion/value}"
                                                            displayValue="{dashboard>/kpis/trainingCompletion/display}"
                                                            state="{dashboard>/kpis/trainingCompletion/state}"/>
                                                    </HBox>
                                                    <HBox class="scorecardRow" justifyContent="SpaceBetween" alignItems="Center">
                                                        <Text text="Task Closure"/>
                                                        <ProgressIndicator
                                                            width="55%"
                                                            percentValue="{dashboard>/kpis/taskClosure/value}"
                                                            displayValue="{dashboard>/kpis/taskClosure/display}"
                                                            state="{dashboard>/kpis/taskClosure/state}"/>
                                                    </HBox>
                                                    <HBox class="scorecardRow" justifyContent="SpaceBetween" alignItems="Center">
                                                        <Text text="Document Readiness"/>
                                                        <ProgressIndicator
                                                            width="55%"
                                                            percentValue="{dashboard>/kpis/documentReadiness/value}"
                                                            displayValue="{dashboard>/kpis/documentReadiness/display}"
                                                            state="{dashboard>/kpis/documentReadiness/state}"/>
                                                    </HBox>
                                                </VBox>
                                            </Panel>
                                            <Panel headerText="Operational Risk" class="dashboardPanel">
                                                <List>
                                                    <ObjectListItem title="Overdue Tasks" number="{dashboard>/kpis/overdueTasks/value}" numberState="{dashboard>/kpis/overdueTasks/state}"/>
                                                    <ObjectListItem title="High Priority Tasks" number="{dashboard>/kpis/highPriorityTasks/value}" numberState="{dashboard>/kpis/highPriorityTasks/state}"/>
                                                    <ObjectListItem title="Pending Documents" number="{dashboard>/kpis/openDocuments/value}" numberState="{dashboard>/kpis/openDocuments/state}"/>
                                                    <ObjectListItem title="Inactive Employees" number="{dashboard>/kpis/inactiveEmployees/value}" numberState="{dashboard>/kpis/inactiveEmployees/state}"/>
                                                </List>
                                            </Panel>
                                        </HBox>
                                    </VBox>
                                </IconTabFilter>

                                <IconTabFilter key="charts" text="Charts" icon="sap-icon://business-objects-mobile">
                                    <VBox class="dashboardTabContent">
                                        <HBox class="dashboardColumns" renderType="Bare" wrap="Wrap" alignItems="Stretch">
                                            <Panel headerText="Employee Status" class="dashboardPanel">
                                                <List items="{dashboard>/statusDistribution}" showSeparators="Inner">
                                                    <CustomListItem>
                                                        <VBox class="chartRow">
                                                            <HBox justifyContent="SpaceBetween">
                                                                <ObjectStatus text="{dashboard>status}" state="{dashboard>state}"/>
                                                                <Text text="{dashboard>shareText}"/>
                                                            </HBox>
                                                            <ProgressIndicator
                                                                percentValue="{dashboard>share}"
                                                                displayValue="{dashboard>countText}"
                                                                state="{dashboard>state}"/>
                                                        </VBox>
                                                    </CustomListItem>
                                                </List>
                                            </Panel>
                                            <Panel headerText="Task Status" class="dashboardPanel">
                                                <List items="{dashboard>/taskDistribution}" showSeparators="Inner">
                                                    <CustomListItem>
                                                        <VBox class="chartRow">
                                                            <HBox justifyContent="SpaceBetween">
                                                                <ObjectStatus text="{dashboard>status}" state="{dashboard>state}"/>
                                                                <Text text="{dashboard>shareText}"/>
                                                            </HBox>
                                                            <ProgressIndicator
                                                                percentValue="{dashboard>share}"
                                                                displayValue="{dashboard>countText}"
                                                                state="{dashboard>state}"/>
                                                        </VBox>
                                                    </CustomListItem>
                                                </List>
                                            </Panel>
                                            <Panel headerText="Asset Availability" class="dashboardPanel">
                                                <List items="{dashboard>/assetDistribution}" showSeparators="Inner">
                                                    <CustomListItem>
                                                        <VBox class="chartRow">
                                                            <HBox justifyContent="SpaceBetween">
                                                                <ObjectStatus text="{dashboard>status}" state="{dashboard>state}"/>
                                                                <Text text="{dashboard>shareText}"/>
                                                            </HBox>
                                                            <ProgressIndicator
                                                                percentValue="{dashboard>share}"
                                                                displayValue="{dashboard>countText}"
                                                                state="{dashboard>state}"/>
                                                        </VBox>
                                                    </CustomListItem>
                                                </List>
                                            </Panel>
                                        </HBox>
                                    </VBox>
                                </IconTabFilter>

                                <IconTabFilter key="worklist" text="Worklist" icon="sap-icon://activities">
                                    <VBox class="dashboardTabContent">
                                        <HBox class="dashboardColumns" renderType="Bare" wrap="Wrap" alignItems="Stretch">
                                            <Panel headerText="Priority Task Queue" class="dashboardPanel widePanel">
                                                <Table items="{dashboard>/priorityTasks}" noDataText="No open priority tasks">
                                                    <columns>
                                                        <Column><Text text="Task"/></Column>
                                                        <Column><Text text="Owner"/></Column>
                                                        <Column><Text text="Due Date"/></Column>
                                                        <Column><Text text="Priority"/></Column>
                                                        <Column><Text text="Status"/></Column>
                                                    </columns>
                                                    <items>
                                                        <ColumnListItem>
                                                            <cells>
                                                                <Text text="{dashboard>taskName}"/>
                                                                <Text text="{dashboard>assignedTo}"/>
                                                                <Text text="{dashboard>dueDateText}"/>
                                                                <ObjectStatus text="{dashboard>priority}" state="{dashboard>priorityState}"/>
                                                                <ObjectStatus text="{dashboard>status}" state="{dashboard>state}"/>
                                                            </cells>
                                                        </ColumnListItem>
                                                    </items>
                                                </Table>
                                            </Panel>
                                            <Panel headerText="Document Queue" class="dashboardPanel">
                                                <List items="{dashboard>/documentQueue}" noDataText="No open documents">
                                                    <ObjectListItem
                                                        title="{dashboard>documentType}"
                                                        intro="{dashboard>fileName}"
                                                        number="{dashboard>status}"
                                                        numberState="{dashboard>state}">
                                                        <attributes>
                                                            <ObjectAttribute text="{dashboard>uploadedDateText}"/>
                                                        </attributes>
                                                    </ObjectListItem>
                                                </List>
                                            </Panel>
                                        </HBox>
                                    </VBox>
                                </IconTabFilter>
                            </items>
                        </IconTabBar>
                    </VBox>
                </ScrollContainer>
            </content>
        </Page>
    </App>
</mvc:View>
