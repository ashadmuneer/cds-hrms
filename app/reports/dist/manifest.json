{
	"_version": "2.0.0",
	"sap.app": {
		"id": "reports",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:alp",
			"version": "1.24.0",
			"toolsId": "f92835b8-9a2c-494e-9d26-2c626031ae6e"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/onboarding/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"Reports-display": {
					"semanticObject": "Reports",
					"action": "display",
					"title": "{{appTitle}}",
					"signature": {
						"parameters": {}
					},
					"resolutionResult": {
						"applicationType": "SAPUI5",
						"additionalInformation": "SAPUI5.Component=reports",
						"url": ""
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.136.7",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "reports.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "EmployeeOverviewList",
					"target": "EmployeeOverviewList"
				},
				{
					"pattern": "EmployeeOverview({key}):?query:",
					"name": "EmployeeOverviewObjectPage",
					"target": "EmployeeOverviewObjectPage"
				}
			],
			"targets": {
				"EmployeeOverviewList": {
					"type": "Component",
					"id": "EmployeeOverviewList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/EmployeeOverview",
							"variantManagement": "Page",
							"navigation": {
								"EmployeeOverview": {
									"detail": {
										"route": "EmployeeOverviewObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "AnalyticalTable",
										"selectionMode": "None"
									}
								}
							},
							"views": {
								"paths": [
									{
										"primary": [
											{
												"annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant"
											}
										],
										"secondary": [
											{
												"annotationPath": "com.sap.vocabularies.UI.v1.LineItem"
											}
										],
										"defaultPath": "both"
									}
								]
							}
						}
					}
				},
				"EmployeeOverviewObjectPage": {
					"type": "Component",
					"id": "EmployeeOverviewObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/EmployeeOverview"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "analytical"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	}
}