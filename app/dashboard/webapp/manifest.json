{
  "_version": "2.0.0",
  "sap.app": {
    "id": "dashboard",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:alp",
      "version": "1.24.0",
      "toolsId": "07d7f0bd-9888-4d0d-8309-d7733ddc4b31"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/onboarding/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "Dashboard-display": {
          "semanticObject": "Dashboard",
          "action": "display",
          "title": "{{appTitle}}",
          "signature": {
            "parameters": {}
          },
          "resolutionResult": {
            "applicationType": "SAPUI5",
            "additionalInformation": "SAPUI5.Component=dashboard",
            "url": ""
          }
        }
      },
      "outbounds": {
        "toEmployees": {
          "semanticObject": "Employees",
          "action": "manage",
          "title": "{{employees}}"
        },
        "toDepartments": {
          "semanticObject": "Departments",
          "action": "manage",
          "title": "{{departments}}"
        },
        "toOnboardingTasks": {
          "semanticObject": "OnboardingTasks",
          "action": "manage",
          "title": "{{tasks}}"
        },
        "toDocuments": {
          "semanticObject": "Documents",
          "action": "manage",
          "title": "{{documents}}"
        },
        "toAssets": {
          "semanticObject": "Assets",
          "action": "manage",
          "title": "{{assets}}"
        },
        "toTrainings": {
          "semanticObject": "Trainings",
          "action": "manage",
          "title": "{{training}}"
        },
        "toReports": {
          "semanticObject": "Reports",
          "action": "display",
          "title": "{{reports}}"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.7",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "dashboard.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/dashboard.css"
        }
      ]
    },
    "rootView": {
      "viewName": "dashboard.view.App",
      "type": "XML",
      "id": "app"
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
